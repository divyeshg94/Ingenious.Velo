{
  "manifestVersion": 1,
  "id": "velo",
  "name": "Velo – DORA Metrics & AI Pipeline Intelligence for Azure DevOps",
  "version": "1.0.51",
  "publisher": "IngeniousLabs",
  "public": true,
  "description": "Track all 5 DORA metrics automatically from Azure DevOps pipelines and PRs, with an AI agent for delivery insights.",
  "categories": ["Azure Pipelines"],
  "tags": ["dora", "dora-metrics", "devops", "ai", "pipeline-analytics", "engineering-metrics", "azure-pipelines", "gpt-4o", "azure-ai-foundry", "lead-time", "deployment-frequency"],
  "targets": [
    { "id": "Microsoft.VisualStudio.Services" }
  ],
  "files": [
    {
      "path": "dist/velo-extension",
      "addressable": true
    },
    {
      "path": "tasks/VeloTask"
    },
    {
      "path": "images",
      "addressable": true
    },
    {
      "path": "docs/screenshots",
      "addressable": true
    },
    {
      "path": "README.md",
      "addressable": true
    }
  ],
  "icons": {
    "default": "images/catalog-icon.png"
  },
  "content": {
    "details": {
      "path": "README.md"
    },
    "screenshots": [
      { "path": "docs/screenshots/Dashboard1.png" },
      { "path": "docs/screenshots/Dashboard2.png" },
      { "path": "docs/screenshots/DORAMetrics1.png" },
      { "path": "docs/screenshots/DORAMetrics2.png" },
      { "path": "docs/screenshots/TeamHealth.png" },
      { "path": "docs/screenshots/Pipelines.png" },
      { "path": "docs/screenshots/AIAgents.png" },
      { "path": "docs/screenshots/Teams.png" },
      { "path": "docs/screenshots/Connections1.png" },
      { "path": "docs/screenshots/Connections2.png" }
    ]
  },
  "links": {
    "repository": {
      "uri": "https://github.com/divyeshg94/Ingenious.Velo"
    },
    "documentation": {
      "uri": "https://github.com/divyeshg94/Ingenious.Velo/tree/master/docs"
    },
    "issues": {
      "uri": "https://github.com/divyeshg94/Ingenious.Velo/issues"
    }
  },
  "scopes": [
    "vso.build",
    "vso.code",
    "vso.work",
    "vso.analytics",
    "vso.hooks_write"
  ],
  "contributions": [
    {
      "id": "velo-hub-group",
      "type": "ms.vss-web.hub-group",
      "description": "Velo engineering intelligence hub group",
      "targets": ["ms.vss-web.project-hub-groups-collection"],
      "properties": {
        "name": "Velo",
        "order": 99,
        "icon": {
          "light": "images/catalog-icon.png",
          "dark": "images/catalog-icon.png"
        }
      }
    },
    {
      "id": "velo-hub",
      "type": "ms.vss-web.hub",
      "description": "Velo engineering intelligence dashboard",
      "targets": [".velo-hub-group"],
      "properties": {
        "name": "Dashboard",
        "order": 1,
        "uri": "dist/velo-extension/index.html"
      }
    },
    {
      "id": "velo-dora-widget",
      "type": "ms.vss-dashboards-web.widget",
      "description": "Compact DORA metrics tile for Azure DevOps dashboards",
      "targets": ["ms.vss-dashboards-web.widget-catalog"],
      "properties": {
        "name": "Velo DORA Metrics",
        "description": "Display DORA metrics for your project",
        "uri": "dist/velo-extension/widget.html",
        "supportedSizes": [
          { "rowSpan": 1, "columnSpan": 2 },
          { "rowSpan": 2, "columnSpan": 2 }
        ],
        "supportedScopes": ["project_team"],
        "catalogIconUrl": "images/catalog-icon.png",
        "previewImageUrl": "images/catalog-icon.png"
      }
    },
    {
      "id": "velo-pipeline-task",
      "type": "ms.vss-distributed-task.task",
      "description": "Velo pipeline instrumentation task",
      "targets": ["ms.vss-distributed-task.tasks"],
      "properties": {
        "name": "tasks/VeloTask"
      }
    }
  ]
}
