{
  "name": "velo-extension",
  "version": "1.0.0",
  "scripts": {
    "start": "npx ng serve",
    "build": "npx ng build --configuration production",
    "build:dev": "npx ng build",
    "lint": "ng lint",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "package": "tfx extension create --manifest-globs vss-extension.json",
    "publish:dev": "tfx extension publish --manifest-globs vss-extension.json --env dev"
  },
  "clean-install": {
    "windows": "powershell -ExecutionPolicy Bypass -File ./scripts/clean-install.ps1",
    "default": "rm -rf node_modules && npm ci"
  },
  "dependencies": {
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "azure-devops-extension-api": "^4.0.0",
    "azure-devops-extension-sdk": "^4.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.7.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "tfx-cli": "^0.16.0",
    "typescript": "~5.6.0"
  }
}
