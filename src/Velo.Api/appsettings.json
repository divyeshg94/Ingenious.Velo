{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "VeloDb",
          "sinkOptions": {
            "tableName": "log_events",
            "autoCreateSqlTable": false,
            "batchPostingLimit": 50,
            "period": "0:0:10"
          },
          "columnOptions": {
            "message": {
              "columnName": "Message"
            },
            "messageTemplate": {
              "columnName": "MessageTemplate"
            },
            "level": {
              "columnName": "Level"
            },
            "timeStamp": {
              "columnName": "TimeStamp",
              "convertToUtc": true
            },
            "exception": {
              "columnName": "Exception"
            },
            "properties": {
              "columnName": "Properties"
            },
            "logEvent": {
              "columnName": "EventData"
            },
            "additionalColumns": [
              {
                "columnName": "OrgId",
                "propertyName": "OrgId",
                "dataType": "nvarchar",
                "dataLength": 256
              },
              {
                "columnName": "UserId",
                "propertyName": "UserId",
                "dataType": "nvarchar",
                "dataLength": 256
              },
              {
                "columnName": "CorrelationId",
                "propertyName": "CorrelationId",
                "dataType": "nvarchar",
                "dataLength": 128
              },
              {
                "columnName": "RequestPath",
                "propertyName": "RequestPath",
                "dataType": "nvarchar",
                "dataLength": 1024
              },
              {
                "columnName": "RequestMethod",
                "propertyName": "RequestMethod",
                "dataType": "nvarchar",
                "dataLength": 10
              },
              {
                "columnName": "StatusCode",
                "propertyName": "StatusCode",
                "dataType": "int"
              },
              {
                "columnName": "DurationMs",
                "propertyName": "DurationMs",
                "dataType": "int"
              }
            ]
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithProperty",
      "WithThreadId",
      "WithEnvironmentUserName"
    ],
    "Properties": {
      "Application": "Velo.Api",
      "Environment": "Production"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "VeloDb": "Data Source=localhost;Initial Catalog=Velo;User ID=sa; Password=pass@word1; TrustServerCertificate=True;"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "Audience": ""
  },
  "AzureDevOps": {
    "Audience": "DivyeshGovaerdhanan.velo"
  },
  "Foundry": {
    "Endpoint": "",
    "AgentId": "",
    "DailyTokenBudgetPerOrg": 50000
  },
  "Cors": {
    "AllowedOrigins": [
      "https://dev.azure.com",
      "https://extmgmt.dev.azure.com",
      "https://*.visualstudio.com",
      "https://*.dev.azure.com",
      "https://*.gallerycdn.vsassets.io"
    ],
    "ExposedHeaders": [
      "X-Correlation-ID"
    ]
  }
}
